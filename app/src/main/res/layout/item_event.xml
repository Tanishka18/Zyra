<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Left colored bar for risk -->

        <!-- Event Content -->
        <View
            android:id="@+id/viewRiskBar"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_marginStart="23dp"
            android:layout_marginEnd="12dp"
            android:background="@color/colorSafe" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/viewRiskBar"
            android:orientation="vertical">

            <!-- Event Type + Modality -->
            <TextView
                android:id="@+id/tvEventType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspicious • Typing"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimaryLight" />

            <!-- Event Description -->
            <TextView
                android:id="@+id/tvEventDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unusual typing rhythm detected"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="@color/textSecondaryLight" />

            <!-- Timestamp + Risk Chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvEventTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025-08-20 12:55"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondaryLight" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRisk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe"
                    android:textSize="12sp"
                    app:chipCornerRadius="8dp"
                    app:chipStrokeWidth="0dp"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textColor="@android:color/white"
                    app:chipBackgroundColor="@color/colorSafe"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
